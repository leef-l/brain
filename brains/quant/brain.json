{
  "schema_version": 1,
  "kind": "quant",
  "name": "Quant Brain",
  "brain_version": "1.0.0",
  "description": "量化策略执行：仓位管理、风控、下单、回测、自适应学习",
  "capabilities": [
    "trading.portfolio",
    "trading.risk",
    "trading.execute",
    "trading.learn",
    "trading.backtest",
    "domain.quantitative_trading",
    "resource.exchange_account",
    "mode.background",
    "mode.interactive"
  ],
  "runtime": {
    "type": "native",
    "entrypoint": "brain-quant-sidecar"
  },
  "policy": {
    "approval_class": "control-plane",
    "approval_mode": "review",
    "sandbox_profile": "workspace",
    "tool_scope": "quant"
  },
  "task_patterns": [
    "仓位与风控查询",
    "策略执行与下单",
    "回测与评估",
    "自适应权重调整"
  ],
  "health": {
    "startup_timeout_ms": 5000,
    "heartbeat_timeout_ms": 30000,
    "expected_methods": [
      "brain/execute",
      "brain/tools_list",
      "brain/metrics"
    ]
  },
  "compatibility": {
    "min_kernel_version": "1.0.0"
  }
}