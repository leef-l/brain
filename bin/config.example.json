{
  "mode": "solo",
  "default_brain": "central",
  "chat_mode": "accept-edits",
  "permission_mode": "restricted",
  "serve_workdir_policy": "confined",
  "timeout": "30m",
  "log_level": "info",
  "no_color": false,

  "active_provider": "anthropic",
  "providers": {
    "anthropic": {
      "base_url": "https://api.anthropic.com",
      "api_key": "sk-ant-xxxxx",
      "model": "claude-sonnet-4-20250514",
      "models": {
        "central": "claude-sonnet-4-20250514",
        "code": "claude-sonnet-4-20250514",
        "verifier": "claude-haiku-4-5-20251001"
      }
    }
  },

  "default_budget": {
    "max_turns": 20,
    "max_cost_usd": 5.0
  },

  "tool_profiles": {
    "coding_no_shell": {
      "include": ["code.*", "central.delegate"],
      "exclude": ["*.shell_exec"]
    },
    "verifier_readonly": {
      "include": ["verifier.*"],
      "exclude": ["verifier.browser_action"]
    }
  },
  "active_tools": {
    "chat.central.default": "coding_no_shell",
    "delegate.code": "coding_no_shell",
    "delegate.verifier": "verifier_readonly"
  },

  "sandbox": {
    "enabled": true,
    "allow_write": [],
    "deny_read": ["~/.ssh", "~/.aws"],
    "allow_net": [],
    "fail_if_unavailable": false
  },

  "file_policy": {
    "allow_read": ["cmd/**/*.go", "tool/**/*.go", "README.md"],
    "allow_create": ["docs/*.md"],
    "allow_edit": ["cmd/**/*.go"],
    "allow_delete": [],
    "allow_commands": true,
    "allow_delegate": true,
    "deny": [".git/**", "**/.env", "**/secrets/**"]
  }
}
